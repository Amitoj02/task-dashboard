# Source — only the bundled output ships.
src/**
out/**
.vscode-test/**
.vscode-test.mjs
node_modules/**

# Build & tooling configs.
esbuild.js
tsconfig*.json
eslint.config.mjs
.eslintrc*
.prettierrc.json
.prettierignore
.mocharc.json

# Project files not needed at runtime.
.github/**
.vscode/**
.claude/**
.gitignore
.git/**
CONTRIBUTING.md
**/*.ts
**/*.map
*.vsix
pnpm-lock.yaml
pnpm-workspace.yaml
.npmrc

# README screenshots ship via absolute raw-GitHub URLs (see README.md), so they
# render on the Marketplace and in-editor without bloating the VSIX (~1.4 MB).
media/screenshots/**
# Editable icon source; only the rendered media/icon.png is needed at runtime.
media/icon.svg

# Keep: dist/, media/ (webview assets, icon.png, task-dashboard.svg), package.json,
# README.md, CHANGELOG.md, LICENSE
